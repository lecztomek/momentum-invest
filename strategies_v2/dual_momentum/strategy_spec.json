{
  "name": "dual_momentum_v0",
  "hypothesis": "Dual momentum wieloaktywowe: absolutny momentum 12m jako filtr (tylko aktywa z dodatnim wlasnym momentum, inaczej cash), scoring tez na 12m momentum, top3, wagi odwrotne do zmiennosci 60-dniowej (risk-parity-lite) zamiast rankingowych wag stalych.",
  "universe": ["spy.us", "efa.us", "vnq.us", "gld.us", "tlt.us", "hyg.us"],

  "blocks": {
    "data_loader": "stooq_csv",
    "data_cleaner": "trim_and_interpolate",
    "asset_scoring": "weighted_sum",
    "selector": "top_n",
    "alpha_weighting": "inverse_vol",
    "portfolio_risk_engine": "none",
    "overlays": "none",
    "execution": "hysteresis"
  },

  "base_params": {
    "data_loader": {"data_dir": "data/us", "frequency": "monthly"},
    "data_cleaner": {},
    "indicators": {
      "mom_12": {"impl": "momentum_monthly", "window": 12},
      "vol_60": {"impl": "volatility_daily", "window": 60}
    },
    "asset_filters": {
      "abs_momentum": {"impl": "indicator_positive", "indicator_key": "mom_12"}
    },
    "asset_scoring": {"weights": {"mom_12": 1.0}},
    "selector": {"top_n": 3},
    "alpha_weighting": {"volatility_key": "vol_60"},
    "execution": {"hysteresis_pct": 0.05, "cost_bps": 40, "frequency": "monthly"}
  },

  "allowed_param_families": {
    "selector": {"top_n": [2, 3, 4]},
    "execution": {"hysteresis_pct": [0.0, 0.025, 0.05, 0.075, 0.10]}
  },

  "created_at": "2026-07-10"
}
