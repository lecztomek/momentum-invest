{
  "name": "example_v0",
  "hypothesis": "Prosty trend-filter (cena > SMA200) + top2 momentum 3/6/12 powinien dawac stabilna rodzine parametrow wokol tych wartosci, bez potrzeby hedge'a na tym etapie.",
  "universe": ["ivv.us", "xlk.us", "iau.us", "dbc.us", "tlt.us"],

  "blocks": {
    "data_loader": "stooq_csv",
    "data_cleaner": "trim_and_interpolate",
    "asset_scoring": "weighted_sum",
    "selector": "top_n",
    "alpha_weighting": "rank_weights",
    "portfolio_risk_engine": "none",
    "overlays": "none",
    "execution": "hysteresis"
  },

  "base_params": {
    "data_loader": {"data_dir": "data/us", "frequency": "monthly"},
    "data_cleaner": {},
    "indicators": {
      "sma_200": {"impl": "sma_daily", "window": 200},
      "mom_3": {"impl": "momentum_monthly", "window": 3},
      "mom_6": {"impl": "momentum_monthly", "window": 6},
      "mom_12": {"impl": "momentum_monthly", "window": 12}
    },
    "asset_filters": {
      "trend": {"impl": "price_above_indicator", "indicator_key": "sma_200"}
    },
    "asset_scoring": {"weights": {"mom_3": 0.5, "mom_6": 0.3, "mom_12": 0.2}},
    "selector": {"top_n": 2},
    "alpha_weighting": {"weights": [0.8, 0.2]},
    "execution": {"hysteresis_pct": 0.05, "cost_bps": 10, "frequency": "monthly"}
  },

  "allowed_param_families": {
    "execution": {"hysteresis_pct": [0.0, 0.025, 0.05, 0.075, 0.10]},
    "indicators": {"sma_200.window": [150, 200, 250]}
  },

  "created_at": "2026-07-10"
}
